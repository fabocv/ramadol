
---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import 'katex/dist/katex.min.css';
import ramadol from "../assets/ramadol.png";
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <script data-goatcounter="https://ramadol.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
</head>

<style>
  /* ── banda scrolling ── */
  .prospecto-band {
    background: var(--accent);
    color: rgb(var(--bg));
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    overflow: hidden;
    white-space: nowrap;
    padding: 6px 0;
  }

  .prospecto-scroll {
    display: inline-block;
    animation: scroll-band 28s linear infinite;
    white-space: nowrap;
  }

  @keyframes scroll-band {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── hero ── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid rgb(var(--gray-light));
    min-height: 420px;
  }

  .hero-left {
    padding: 3.5rem 2rem 3.5rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid rgb(var(--gray-light));
  }

  .hero-eyebrow {
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
    font-weight: 600;
  }

  .hero-title {
    font-size: clamp(2.8rem, 8vw, 4rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: rgb(var(--black));
    margin: 0 0 0.1rem 0;
  }

  .hero-dose {
    font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--accent);
    display: block;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .hero-tagline {
    font-size: 14px;
    color: rgb(var(--gray-dark));
    margin-top: 1.25rem;
    line-height: 1.6;
    opacity: 0.7;
  }

  .hero-cta {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--accent);
    color: rgb(var(--bg));
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 9px 20px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    color: rgb(var(--bg));
  }

  .btn-ghost {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--gray-dark));
    opacity: 0.5;
    text-decoration: none;
    border-bottom: 1px solid rgb(var(--gray-light));
    padding-bottom: 1px;
    transition: opacity 0.2s;
  }

  .btn-ghost:hover {
    opacity: 1;
    color: rgb(var(--gray-dark));
  }

  /* ── imagen ── */
  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 2rem;
    background: rgb(var(--bg-elevated));
  }

  .hero-right img {
    max-width: 240px;
    width: 100%;
    height: auto;
    border-radius: 4px;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.5));
  }

  /* ── stats ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 1px solid rgb(var(--gray-light));
  }

  .stat {
    padding: 1.75rem 2rem;
    border-right: 1px solid rgb(var(--gray-light));
  }

  .stat:last-child {
    border-right: none;
  }

  .stat-n {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 10px;
    color: rgb(var(--gray-dark));
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-top: 5px;
    opacity: 0.45;
  }

  /* ── efectos secundarios ── */
  .efectos {
    padding: 2.5rem 2rem;
    border-bottom: 1px solid rgb(var(--gray-light));
  }

  .section-eyebrow {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
    font-weight: 600;
  }

  .efectos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgb(var(--gray-light));
  }

  .efecto-item {
    background: rgb(var(--bg));
    padding: 1.1rem 1.25rem;
  }

  .efecto-icon {
    font-size: 16px;
    margin-bottom: 6px;
    display: block;
    font-style: normal;
  }

  .efecto-name {
    font-size: 12px;
    font-weight: 600;
    color: rgb(var(--black));
    margin-bottom: 3px;
    letter-spacing: 0.01em;
  }

  .efecto-desc {
    font-size: 11px;
    color: rgb(var(--gray-dark));
    line-height: 1.4;
    opacity: 0.5;
  }

  /* ── advertencia ── */
  .advertencia {
    margin: 0 2rem 2.5rem 2rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--accent-muted, #1A3D31);
    background: rgba(0, 179, 126, 0.04);
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .adv-icon {
    color: var(--accent);
    font-weight: 700;
    font-size: 15px;
    line-height: 1.6;
    flex-shrink: 0;
  }

  .adv-text {
    font-size: 12px;
    color: rgb(var(--gray-dark));
    line-height: 1.6;
    opacity: 0.55;
  }

  .adv-text strong {
    color: var(--accent);
    opacity: 1;
    font-weight: 600;
  }

  /* ── responsive ── */
  @media (max-width: 640px) {
    .prospecto-band {
      font-size: 9px;
      letter-spacing: 0.16em;
    }

    .hero {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .hero-left {
      border-right: none;
      border-bottom: 1px solid rgb(var(--gray-light));
      padding: 2.25rem 1.25rem;
    }

    .hero-right {
      padding: 2rem 1.25rem;
      justify-content: center;
    }

    .hero-right img {
      max-width: 200px;
    }

    .stats-row {
      grid-template-columns: repeat(3, 1fr);
    }

    .stat {
      padding: 1.25rem 1rem;
    }

    .stat-n {
      font-size: 1.6rem;
    }

    .stat-label {
      font-size: 9px;
    }

    .efectos {
      padding: 2rem 1.25rem;
    }

    .efectos-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .advertencia {
      margin: 0 1.25rem 2rem 1.25rem;
    }
  }
</style>

<body>
  <Header />

  <div class="prospecto-band">
    <span class="prospecto-scroll">
      &nbsp;&nbsp;PROSPECTO — Leer atentamente antes de consumir &nbsp;·&nbsp; Efectos secundarios: curiosidad excesiva · migración conceptual · preguntas incómodas &nbsp;·&nbsp; No conducir maquinaria pesada tras la lectura &nbsp;·&nbsp; PROSPECTO — Leer atentamente antes de consumir &nbsp;·&nbsp; Efectos secundarios: curiosidad excesiva · migración conceptual · preguntas incómodas &nbsp;·&nbsp; No conducir maquinaria pesada tras la lectura &nbsp;·&nbsp;
    </span>
  </div>

  <div class="hero">
    <div class="hero-left">
      <p class="hero-eyebrow">Vía oral · 1 cápsula diaria</p>
      <h1 class="hero-title">
        Ramadol
        <span class="hero-dose">500mg</span>
      </h1>
      <p class="hero-tagline">
        Dosis diaria de cybercuriosidad con filosofía masticable.<br>
        No te vayas por las ramas.
      </p>
      <div class="hero-cta">
        <a href="/ramadol/blog" class="btn-primary">Leer el blog</a>
        <a href="/ramadol/about" class="btn-ghost">Sobre el autor →</a>
      </div>
    </div>

    <div class="hero-right">
      <Image src={ramadol} alt="Ramadol 500mg — tratamiento experimental para la curiosidad excesiva." width={240} />
    </div>
  </div>

  <div class="stats-row">
    <div class="stat">
      <div class="stat-n">500</div>
      <div class="stat-label">mg de curiosidad</div>
    </div>
    <div class="stat">
      <div class="stat-n">01</div>
      <div class="stat-label">dosis por día</div>
    </div>
    <div class="stat">
      <div class="stat-n">∞</div>
      <div class="stat-label">ramificaciones</div>
    </div>
  </div>

  <div class="efectos">
    <p class="section-eyebrow">Efectos secundarios frecuentes</p>
    <div class="efectos-grid">
      <div class="efecto-item">
        <em class="efecto-icon">⚡</em>
        <div class="efecto-name">Cybercuriosidad</div>
        <div class="efecto-desc">Urgencia por entender cómo funciona todo</div>
      </div>
      <div class="efecto-item">
        <em class="efecto-icon">◈</em>
        <div class="efecto-name">Migración conceptual</div>
        <div class="efecto-desc">Ideas que viajan sin pedir permiso</div>
      </div>
      <div class="efecto-item">
        <em class="efecto-icon">🜂</em>
        <div class="efecto-name">Filosofía masticable</div>
        <div class="efecto-desc">Teoría que se entiende sin prospecto</div>
      </div>
      <div class="efecto-item">
        <em class="efecto-icon">☕</em>
        <div class="efecto-name">Potenciado con café</div>
        <div class="efecto-desc">Mejor absorbido con cafeína en sangre</div>
      </div>
    </div>
  </div>

  <div class="advertencia">
    <span class="adv-icon">!</span>
    <p class="adv-text">
      <strong>Advertencia:</strong> Este blog puede producir preguntas incómodas, relecturas compulsivas y la molesta sensación de que todo está conectado. No se recomienda su uso en reuniones de trabajo o durante actividades que requieran certeza. Conservar en lugar fresco, alejado de la ignorancia voluntaria.
    </p>
  </div>

  <Footer />
</body>
</html>